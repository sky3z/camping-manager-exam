{
  "info": {
    "name": "Camping Manager Exam",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Collection completa per camping-manager-exam",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "staffToken", "value": "", "type": "string" },
    { "key": "ospiteToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('adminToken', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@camping.it\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('staffToken', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"staff@camping.it\",\n  \"password\": \"Staff123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Ospite",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('ospiteToken', json.token);",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mario.rossi@example.com\",\n  \"password\": \"TempPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Profilo corrente (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Utenti",
      "item": [
        {
          "name": "Aggiorna immagine profilo",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Seleziona un'immagine JPG o PNG"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/me/profile-image",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me", "profile-image"]
            }
          }
        }
      ]
    },
    {
      "name": "Alloggi",
      "item": [
        {
          "name": "Lista tutti gli alloggi",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/accommodations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accommodations"]
            }
          }
        },
        {
          "name": "Alloggi per tipo (CHALET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/accommodations?type=CHALET",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accommodations"],
              "query": [{ "key": "type", "value": "CHALET" }]
            }
          }
        },
        {
          "name": "Alloggi disponibili per date",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/accommodations/available?checkIn=2026-08-01&checkOut=2026-08-07",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accommodations", "available"],
              "query": [
                { "key": "checkIn", "value": "2026-08-01" },
                { "key": "checkOut", "value": "2026-08-07" }
              ]
            }
          }
        },
        {
          "name": "Crea alloggio (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chalet 11\",\n  \"type\": \"CHALET\",\n  \"pricePerNight\": 80.00,\n  \"maxCapacity\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/accommodations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accommodations"]
            }
          }
        },
        {
          "name": "Aggiorna stato alloggio (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
